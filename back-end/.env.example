# MongoDB Atlas connection string
# Get this from your Atlas cluster -> Connect -> Drivers
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority

# Long random string used to sign JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

# Port the Express server listens on
PORT=3001

# Optional. When set to "true" in development, the server will start an
# in-memory MongoDB if MONGO_URI is unreachable. Never enable in production.
# ALLOW_IN_MEMORY_DB=false
